<li class="px-4 py-4 sm:px-6">
  <div class="flex items-center justify-between">
    <div>
      <div class="flex items-center gap-2">
        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
          <%= due_diligence_review.review_type == 'ENHANCED' ? 'bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300' : 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300' %>">
          <%= DueDiligenceReview::REVIEW_TYPE_LABELS[due_diligence_review.review_type] %>
        </span>
        <span class="inline-flex items-center rounded-full bg-gray-100 dark:bg-gray-800 px-2 py-0.5 text-xs font-medium text-gray-600 dark:text-gray-300">
          <%= DueDiligenceReview::TRIGGER_LABELS[due_diligence_review.trigger] %>
        </span>
      </div>
      <% if due_diligence_review.notes.present? %>
        <p class="mt-1 text-sm text-gray-600 dark:text-gray-400"><%= due_diligence_review.notes %></p>
      <% end %>
    </div>
    <div class="text-sm text-gray-500 dark:text-gray-400">
      <%= l(due_diligence_review.performed_at, format: :long) %>
    </div>
  </div>
</li>
